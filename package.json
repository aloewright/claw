{
  "name": "claw",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "Run OpenClaw personal AI assistant in a Cloudflare Sandbox",
  "scripts": {
    "build": "vite build",
    "deploy": "npm run build && wrangler deploy",
    "deploy:doppler": "doppler run -- npm run deploy",
    "dev": "vite dev",
    "start": "wrangler dev",
    "start:doppler": "doppler run -- wrangler dev",
    "secrets:sync": "node scripts/doppler-sync.js",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@cloudflare/puppeteer": "^1.0.5",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "hono": "^4.12.7",
    "jose": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@cloudflare/sandbox": "*",
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20250109.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "@playwright/test": "^1.50.0",
    "wrangler": "^4.50.0"
  },
  "author": "",
  "license": "Apache-2.0",
  "cloudflare": {
    "bindings": {
      "ANTHROPIC_API_KEY": {
        "description": "Your [Anthropic API key](https://console.anthropic.com/)."
      },
      "OPENCLAW_GATEWAY_TOKEN": {
        "description": "Token for gateway access. Generate with: openssl rand -hex 32"
      }
    }
  }
}
